{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intive.local/schemas/id2s-step.schema.json",
  "title": "ID2S Kit Step (catalog)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "title",
    "objective",
    "primary_role_skill",
    "doc_skill",
    "inputs",
    "outputs",
    "completion_criteria"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "primary_role_skill": {
      "type": "string",
      "pattern": "^id2s-role-[a-z][a-z0-9-]*$"
    },
    "doc_skill": {
      "type": "string",
      "pattern": "^id2s-doc-[a-z][a-z0-9-]*$"
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/input" }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/output" }
    },
    "suggested_role_skills": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^id2s-role-[a-z][a-z0-9-]*$"
      }
    },
    "completion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["artifact", "step_completed"]
        },
        "path": { "type": "string", "minLength": 1 },
        "step_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "required": { "type": "boolean", "default": true },
        "description": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "template"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "template": { "type": "string", "minLength": 1 },
        "agent_ready_path": { "type": "string", "minLength": 1 }
      }
    }
  }
}
