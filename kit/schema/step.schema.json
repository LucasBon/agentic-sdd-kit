{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intive.local/schemas/ask-step.schema.json",
  "title": "Agentic SDD Kit Step (catalog)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "title",
    "objective",
    "primary_role_skill",
    "doc_skill",
    "inputs",
    "outputs",
    "completion_criteria"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "primary_role_skill": {
      "type": "string",
      "pattern": "^ask-role-(?!project-manager$)[a-z][a-z0-9-]*(?<!-delivery)$",
      "description": "Base domain role skill (coach). Delivery uses <role>-delivery generated at bootstrap."
    },
    "engagement_profile": {
      "type": "string",
      "enum": ["coach", "delivery"],
      "default": "coach",
      "description": "How the assigned specialist should engage on this step."
    },
    "doc_skill": {
      "type": "string",
      "pattern": "^ask-doc-[a-z][a-z0-9-]*$"
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/input" }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/output" }
    },
    "completion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["artifact", "step_completed"]
        },
        "path": { "type": "string", "minLength": 1 },
        "step_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "required": { "type": "boolean", "default": true },
        "description": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "template"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "template": { "type": "string", "minLength": 1 }
      }
    }
  }
}
