{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intive.local/schemas/sdd-workflow.schema.json",
  "title": "SDD Kit Workflow",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "title", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["file_exists", "any_of", "all_of"]
        },
        "path": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/precondition" }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "template": {
          "type": "string",
          "description": "Path relative to repository root (e.g. kit/templates/sdd/01-project-brief.md.template)"
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "objective",
        "preconditions",
        "outputs",
        "doc_skill",
        "suggested_role_skills",
        "completion_criteria"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "preconditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/precondition" }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/output" }
        },
        "primary_template": {
          "type": "string",
          "description": "Optional convenience pointer; outputs[].template is the source of truth for bootstrap"
        },
        "doc_skill": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Skill folder name under .cursor/skills (e.g. sdd-doc-project-brief)"
        },
        "suggested_role_skills": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        },
        "completion_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
