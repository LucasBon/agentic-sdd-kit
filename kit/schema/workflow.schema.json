{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intive.local/schemas/id2s-workflow.schema.json",
  "title": "ID2S Kit Workflow",
  "oneOf": [
    { "$ref": "#/$defs/legacyWorkflow" },
    { "$ref": "#/$defs/composedWorkflow" }
  ],
  "$defs": {
    "workflowMeta": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      },
      "required": ["id", "version", "title"]
    },
    "legacyWorkflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "title", "steps"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/inlineStep" }
        }
      }
    },
    "composedWorkflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "title", "stages"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stage" }
        }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "parallel", "steps"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "parallel": { "type": "boolean" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          }
        }
      }
    },
    "precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["file_exists", "any_of", "all_of"]
        },
        "path": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/precondition" }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "template": {
          "type": "string",
          "description": "Path relative to repository root"
        }
      }
    },
    "inlineStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "objective",
        "preconditions",
        "outputs",
        "primary_role_skill",
        "doc_skill",
        "completion_criteria"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "preconditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/precondition" }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/output" }
        },
        "primary_template": { "type": "string" },
        "primary_role_skill": {
          "type": "string",
          "pattern": "^id2s-role-[a-z][a-z0-9-]*$"
        },
        "doc_skill": {
          "type": "string",
          "pattern": "^id2s-doc-[a-z][a-z0-9-]*$"
        },
        "completion_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
